<quiz>
  <question id="q1">
    <text>Que signifie « meeting » dans un contexte professionnel ?</text>
    <option id="A">A. Une pause</option>
    <option id="B">B. Une réunion</option>
    <option id="C">C. Une tâche</option>
    <correct_answer>B</correct_answer>
  </question>

